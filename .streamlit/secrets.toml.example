# 이 파일을 secrets.toml 로 복사한 뒤 값을 채우세요. (secrets.toml 은 git에 올라가지 않음)
# Streamlit Community Cloud 에서는 앱 Settings > Secrets 에 아래 [smtp] 블록을 그대로 붙여넣습니다.

[smtp]
host = "smtp.gmail.com"
port = 465                       # 465(SSL) 권장, 또는 587(STARTTLS)
user = "sungyoul81@gmail.com"    # 발신 Gmail 주소
password = "xxxxxxxxxxxxxxxx"     # Gmail 앱 비밀번호 16자리(공백 없이)
sender = "sungyoul81@gmail.com"  # 보내는 사람(보통 user와 동일)
recipients = "sungyoul81@gmail.com"  # 받는 사람. 여러 명이면 콤마로: "a@x.com, b@y.com"
